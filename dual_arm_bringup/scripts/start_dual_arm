#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

if [[ -f /opt/ros/humble/setup.bash ]]; then
  # shellcheck disable=SC1091
  source /opt/ros/humble/setup.bash
fi

if [[ -f "${ROOT_DIR}/install/setup.bash" ]]; then
  # shellcheck disable=SC1091
  source "${ROOT_DIR}/install/setup.bash"
else
  echo "install/setup.bash 不存在，先在工作区执行 colcon build" >&2
  exit 1
fi

cleanup_patterns=(
  'ros2 launch .*dual_arm_'
  'move_group'
  'ros2_control_node'
  'servo_node_main'
  'joint_state_broadcaster'
  'keyboard_teleop.py'
  'trajectory_bridge.py'
  'soem_bridge_node'
  'rviz2'
)

found=0
for pattern in "${cleanup_patterns[@]}"; do
  if pgrep -af "$pattern" >/tmp/dual_arm_preflight.$$ 2>/dev/null; then
    if [[ $found -eq 0 ]]; then
      echo "发现残留的双臂相关 ROS 进程，正在清理："
      found=1
    fi
    cat /tmp/dual_arm_preflight.$$
    pkill -TERM -f "$pattern" || true
  fi
done
rm -f /tmp/dual_arm_preflight.$$

if [[ $found -eq 1 ]]; then
  sleep 2
  for pattern in "${cleanup_patterns[@]}"; do
    if pgrep -af "$pattern" >/dev/null 2>&1; then
      pkill -KILL -f "$pattern" || true
    fi
  done
fi

if [[ $# -eq 0 ]]; then
  set -- mode:=servo
fi

exec ros2 launch dual_arm_bringup sim.launch.py "$@"
